# ── Django ─────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# 32 random bytes, base64-encoded, used as the AES-256-GCM vault master key.
# Generate: python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
VAULT_MASTER_KEY_BASE64=

# Fly.io
FLY_API_TOKEN=
FLY_API_BASE_URL=https://api.machines.dev
FLY_ORG_SLUG=personal

# Supabase
SUPABASE_ACCESS_TOKEN=
SUPABASE_API_BASE_URL=https://api.supabase.com
SUPABASE_ORG_ID=
SUPABASE_DEFAULT_REGION=us-east-1

# Stripe
STRIPE_SECRET_KEY=
STRIPE_API_BASE_URL=https://api.stripe.com

# Cloudflare (DNS + Universal SSL)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_BASE_URL=https://api.cloudflare.com/client/v4
DEPLOY_DNS_TARGET=203.0.113.10

# Audit log is persisted in the SQLite database (db.sqlite3); no path needed.

# RBAC (comma-separated API keys per role). Leave empty in dev to default to admin.
RBAC_ADMIN_KEYS=
RBAC_OPERATOR_KEYS=
RBAC_VIEWER_KEYS=
